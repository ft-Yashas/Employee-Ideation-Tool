# ─────────────────────────────────────────────────────────────────────────────
#  IFQM Backend — environment configuration
#
#  Copy to `.env` and fill in real values. NEVER commit the real .env.
#
#  In production the server REFUSES TO START if the secrets below are missing,
#  left at their example values, or obviously unsafe (empty DB password, root DB
#  user, localhost CORS). That is deliberate — a silently-insecure default is
#  worse than a crash. See docs/DEPLOYMENT.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP ─────────────────────────────────────────────────────────────────────
PORT=4000

# Set to `production` on the real server. Enables the strict config checks,
# HSTS, HTTPS redirection, and fail-closed tenant resolution.
NODE_ENV=production

# Exact origin(s) of the React frontend, comma-separated, no trailing slash.
# Must not be localhost in production.
CORS_ORIGIN=https://ideas.yourcompany.com

# Public URL of the frontend — used to build the link inside password-reset
# emails. Must be https in production, or the reset token travels in the clear.
FRONTEND_BASE_URL=https://ideas.yourcompany.com

# Redirect http→https and send HSTS. Defaults to true when NODE_ENV=production.
FORCE_HTTPS=true

# ── Auth ─────────────────────────────────────────────────────────────────────
# The key every session token is signed with. Anyone who knows it can mint a
# token for ANY user in ANY tenant, including an admin — treat it like a root
# password. Minimum 32 chars. Generate a fresh one per environment:
#
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
# Rotating it logs everyone out — that is the "revoke all sessions" lever.
JWT_SECRET=

# Session lifetime in seconds (28800 = 8h).
JWT_EXPIRES_IN=28800

# Minimum length for any password the app accepts.
MIN_PASSWORD_LENGTH=12

# Failed logins per IP per 15 min before throttling. The per-account lockout
# (5 strikes → 15 min) is separate and always on.
AUTH_RATE_LIMIT=30

# ── Database ─────────────────────────────────────────────────────────────────
# The app reaches EVERY tenant schema with this one account. Do not use root:
# create a least-privilege user restricted to the `ifqm_%` schemas — the exact
# GRANT statements are in docs/DEPLOYMENT.md.
APP_DB_USER=ifqm_app
APP_DB_PASS=

# Master registry: which organisations exist, and which schema each lives in.
MASTER_DB_HOST=localhost
MASTER_DB_NAME=ifqm_master
MASTER_DB_USER=ifqm_app
MASTER_DB_PASS=

# Single-tenant fallback, used only when there is no master registry (dev).
FALLBACK_DB_HOST=localhost
FALLBACK_DB_NAME=ifqm_ideation

# ── Gamification points ──────────────────────────────────────────────────────
POINTS_SUBMIT=10
POINTS_APPROVED=25
POINTS_IMPLEMENTED=65

# ── Uploads ──────────────────────────────────────────────────────────────────
MAX_FILE_MB=10

# ── AI scoring (optional) ────────────────────────────────────────────────────
# Leave AI_PROVIDER blank to use the built-in heuristic scorer and spend nothing.
# AI_PROVIDER = openai | gemini | (blank)
AI_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
