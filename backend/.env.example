# ─────────────────────────────────────────────────────────────
#  IFQM Backend — Environment Configuration
#  Copy to `.env` and adjust. Values mirror the PHP api/config.php
#  constants so behaviour stays identical.
# ─────────────────────────────────────────────────────────────

# HTTP
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (Vite dev server, etc.)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Public URL of the React frontend (used to build emailed reset links)
FRONTEND_BASE_URL=http://localhost:5173

# ── Master DB (tenant registry) — mirrors MASTER_DB_* in config.php ──
MASTER_DB_HOST=localhost
MASTER_DB_USER=root
MASTER_DB_PASS=
MASTER_DB_NAME=ifqm_master

# ── Fallback tenant DB (fresh installs without master DB) ──
FALLBACK_DB_HOST=localhost
FALLBACK_DB_USER=root
FALLBACK_DB_PASS=
FALLBACK_DB_NAME=ifqm_ideation

# ── Auth (replaces PHP sessions) ──
# JWT_EXPIRES_IN mirrors SESSION_LIFETIME (28800s = 8h idle window)
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=28800

# ── Gamification points — mirror POINTS_* in config.php ──
POINTS_SUBMIT=10
POINTS_APPROVED=25
POINTS_IMPLEMENTED=65

# ── Uploads ──
MAX_FILE_MB=10

# ── AI providers (left blank on purpose — heuristic fallback is used) ──
# Set exactly one to enable live scoring. AI_PROVIDER = openai | gemini | (blank)
AI_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
