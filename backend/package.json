{
  "name": "ifqm-backend",
  "version": "1.0.0",
  "description": "IFQM Ideation Platform \u2014 Node/Express/MySQL backend (migration of the PHP api/*.php layer)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "setup": "node scripts/setup.js",
    "test": "node --test --test-force-exit test/api.test.js",
    "migrate": "node scripts/migrate.js",
    "backup": "node scripts/backup.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^9.0.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
